# ─── Discord ────────────────────────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=purgebot
DATABASE_USER=purgebot
DATABASE_PASSWORD=

# Read replica — point at a real standby in production, or same postgres for local dev.
DATABASE_REPLICA_HOST=postgres
DATABASE_REPLICA_PORT=5432
DATABASE_REPLICA_NAME=purgebot
DATABASE_REPLICA_USER=purgebot
DATABASE_REPLICA_PASSWORD=

# Replication user created automatically on first postgres start.
REPLICATOR_PASSWORD=

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Kafka ───────────────────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092
KAFKA_EVENTS_TOPIC=purgebot-events

# ─── Sentry ──────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_JSON=false

# ─── Service images ──────────────────────────────────────────────────────────
# Use a specific published version (purgebot-*:local for local dev)
INTERACTIONS_IMAGE=
GATEWAY_IMAGE=
PURGE_IMAGE=

# ─── Interactions service ────────────────────────────────────────────────────
INTERACTIONS_ADDR=:8080

# ─── Premium ─────────────────────────────────────────────────────────────────
PREMIUM_SKU_ID=
# Comma-separated list of guild IDs that get premium for free
FREE_PREMIUM_GUILD_IDS=
