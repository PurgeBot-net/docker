# ─── Discord ─────────────────────────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=

# ─── Premium ─────────────────────────────────────────────────────────────────
PREMIUM_SKU_ID=
# Comma-separated list of guild IDs that get premium for free
FREE_PREMIUM_GUILD_IDS=

# ─── Service images ───────────────────────────────────────────────────────────
# Leave blank to use the default published images
INTERACTIONS_IMAGE=
GATEWAY_IMAGE=
PURGER_IMAGE=

# ─── Ports ───────────────────────────────────────────────────────────────────
# Host port bindings — change if you have conflicts on your machine
POSTGRES_PORT=5432
REDIS_PORT=6379
KAFKA_PORT=9092
INTERACTIONS_PORT=8080

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=purgebot
DATABASE_USER=purgebot
DATABASE_PASSWORD=

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Kafka ───────────────────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092
KAFKA_EVENTS_TOPIC=purgebot-events

# ─── Sharding ────────────────────────────────────────────────────────────────
# Number of shards to split into when Discord requests re-sharding (default 2)
SHARD_SPLIT_COUNT=2

# ─── Interactions ─────────────────────────────────────────────────────────────
INTERACTIONS_ADDR=:8080

# ─── Sentry ──────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_JSON=false
